            do {
                // Gera número aleatório de 9 dígitos (100000000 a 999999999)
                $novoId = mt_rand(100000000, 999999999);
                
                // Verifica se o ID já existe
                $stmt = $mysqli->prepare("SELECT id FROM usuarios WHERE id = ?");
                $stmt->bind_param("i", $novoId);
